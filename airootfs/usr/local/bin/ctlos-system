#!/bin/bash

check_pacman_lock() {
  seconds=0
  while [ -e "/var/lib/pacman/db.lck" ]; do
    echo -e "Pacman is not ready. Retrying in 5 seconds..."
    sleep 5
    seconds=$((seconds + 5))
    if [[ "$seconds" -ge 30 ]]; then
      echo -e "Removing stale pacman lock file."
      rm -f /var/lib/pacman/db.lck
      break
    fi
  done
}

## check virtualization
remove_vmware() {
  echo -e "Cleaning up VMware packages..."
  rm -f /etc/xdg/autostart/vmware-user.desktop
  pacman -Qi open-vm-tools &>/dev/null && {
    systemctl disable vmware-vmblock-fuse.service vmtoolsd.service
    pacman -Rns open-vm-tools --noconfirm
  }
  pacman -Qi xf86-video-vmware &>/dev/null && {
    pacman -Rns xf86-video-vmware --noconfirm
  }
  rm -f /etc/systemd/system/multi-user.target.wants/vmtoolsd.service
}

remove_qemu() {
  echo -e "Cleaning up QEMU guest agent..."
  pacman -Qi qemu-guest-agent &>/dev/null && {
    systemctl disable qemu-guest-agent.service
    pacman -Rns qemu-guest-agent --noconfirm
  }
  pacman -Qi spice-vdagent &>/dev/null && {
    pacman -Rns spice-vdagent --noconfirm
  }
}

remove_vbox() {
  echo -e "Cleaning up VirtualBox guest utils..."
  for pkg in virtualbox-guest-utils virtualbox-guest-utils-nox; do
    pacman -Qi "$pkg" &>/dev/null && {
      systemctl disable vboxservice.service
      pacman -Rns "$pkg" --noconfirm
    }
  done
}

remove_all_virt() {
  remove_vmware
  remove_vbox
  remove_qemu
  rm -f /etc/systemd/system/multi-user.target.wants/virtual-machine-check.service
}

virtual_machine_cleanup() {
  check_pacman_lock
  result=$(systemd-detect-virt)
  echo -e "Detected virtualization: $result"
  case "$result" in
    oracle) remove_vmware; remove_qemu ;;
    kvm)    remove_vmware; remove_vbox ;;
    vmware) remove_vbox; remove_qemu ;;
    none)   remove_all_virt ;;
    *)      echo -e "Unknown virtualization: $result. Skipping cleanup." ;;
  esac
}
virtual_machine_cleanup


## check kernel param driver=free or driver=nonfree
kernel_cmdline(){
  for param in $(cat /proc/cmdline); do
    case "${param}" in
      $1=*) echo "${param##*=}"; return 0 ;;
      $1) return 0 ;;
      *) continue ;;
    esac
  done
  [ -n "${2}" ] && echo "${2}"
  return 1
}
get_driver(){
  echo $(kernel_cmdline driver)
}
# free = remove nvidia
res_driver=$(get_driver)
if [[ $res_driver != "nonfree" ]]; then
  pacman -Rns --noconfirm nvidia-dkms nvidia-utils nvidia-settings
fi


del_service() {
  systemctl disable ctlos-system.service
  # rm /etc/systemd/system/ctlos-system.service
}
del_service